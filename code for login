// code for login
#include <stdio.h>
#include <string.h>

int main() {
    char username[50], password[50];

    printf("Enter username: ");
    scanf("%s", username);

    printf("Enter password: ");
    scanf("%s", password);

    if (strcmp(username, "kiot") == 0 && strcmp(password, "123") == 0)
        printf("Logged in\n");
    else
        printf("Invalid username or password\n");

    return 0;
}


